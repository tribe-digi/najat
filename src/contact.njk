---
title: "Contact — Dr Najat Amharar"
description: "Get in touch with Dr Najat Amharar or book a free discovery call to explore how functional medicine can help you."
activePage: contact
headerScrolled: true
---
{% extends "base.njk" %}

{% block content %}

<!-- ===================== PAGE HERO ===================== -->
<section class="page-hero">
  <div class="container">
    <span class="eyebrow">Get in Touch</span>
    <h1>{{ contact.headline }}</h1>
    <div class="divider divider--center"></div>
    <p class="lead">{{ contact.subheadline }}</p>
  </div>
</section>

<!-- ===================== CONTACT ===================== -->
<section class="section">
  <div class="container">
    <div class="contact-grid">

      <!-- Info column -->
      <div class="contact-info" data-reveal>
        <span class="eyebrow">Contact Information</span>
        <h2>We'd love to hear from you</h2>
        <div class="divider"></div>
        <p>{{ contact.intro }}</p>

        <div style="margin-top:36px;">
          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="contact-info__text">
              <strong>Email</strong>
              <span>{{ settings.email }}</span>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.51 2 2 0 0 1 3.6 1.32h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.46z"/>
              </svg>
            </div>
            <div class="contact-info__text">
              <strong>Phone / WhatsApp</strong>
              <span>{{ settings.phone }}</span>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="contact-info__text">
              <strong>Availability</strong>
              <span>Mon–Fri: 9am – 5pm<br>Consultations by appointment</span>
            </div>
          </div>

          <div class="contact-info__item">
            <div class="contact-info__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <div class="contact-info__text">
              <strong>Consultations</strong>
              <span>Available online (worldwide)<br>and in-person ({{ settings.location }})</span>
            </div>
          </div>
        </div>

        <!-- Free call highlight -->
        <div style="background:var(--color-cream);border-radius:12px;padding:28px;margin-top:16px;">
          <div style="font-size:0.75rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--color-gold);margin-bottom:10px;">Free Discovery Call</div>
          <p style="font-size:0.95rem;font-weight:500;color:var(--color-primary);margin-bottom:8px;">Not sure where to start?</p>
          <p style="font-size:0.88rem;color:var(--color-text-light);margin:0;">Book a free 20-minute call to discuss your health concerns — no pressure, no obligation.</p>
        </div>
      </div>

      <!-- Form column -->
      <div data-reveal>
        <div style="background:var(--color-cream);border-radius:16px;padding:44px 40px;">
          <h3 style="margin-bottom:6px;">Send a message</h3>
          <p style="font-size:0.9rem;color:var(--color-text-light);margin-bottom:28px;">Fill in the form below and Dr Najat's team will be in touch shortly.</p>

          <!-- Netlify form — name attribute is required for Netlify to detect it -->
          <form
            id="contact-form"
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p style="display:none;"><input name="bot-field" /></p>

            <div class="form-row">
              <div class="form-group">
                <label for="first-name">First Name *</label>
                <input type="text" id="first-name" name="first-name" required placeholder="Jane" />
              </div>
              <div class="form-group">
                <label for="last-name">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required placeholder="Smith" />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" required placeholder="jane@example.com" />
            </div>

            <div class="form-group">
              <label for="phone">Phone / WhatsApp</label>
              <input type="tel" id="phone" name="phone" placeholder="+44 7XXX XXX XXX" />
            </div>

            <div class="form-group">
              <label for="reason">What brings you here? *</label>
              <select id="reason" name="reason" required>
                <option value="" disabled selected>Please select…</option>
                <option value="discovery-call">Book a free discovery call</option>
                <option value="initial-consultation">Book an initial consultation</option>
                <option value="hormone-gut">Hormone &amp; gut health enquiry</option>
                <option value="wellness-programme">Wellness programme enquiry</option>
                <option value="general">General question</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Tell me about your health concerns *</label>
              <textarea id="message" name="message" required placeholder="Briefly describe your main symptoms, how long you've had them, and what you've tried so far…"></textarea>
            </div>

            <button type="submit" class="btn btn--primary" style="width:100%;justify-content:center;padding:16px;">
              Send Message
            </button>

            <p style="font-size:0.78rem;color:var(--color-text-light);text-align:center;margin-top:14px;margin-bottom:0;">
              Your information is kept strictly confidential. We'll respond within 1–2 business days.
            </p>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ===================== FAQ ===================== -->
<section class="section section--cream">
  <div class="container">
    <div class="section-header section-header--center" data-reveal>
      <span class="eyebrow">Common Questions</span>
      <h2>Before you get in touch</h2>
      <div class="divider divider--center"></div>
    </div>

    <div style="max-width:740px;margin:0 auto;display:flex;flex-direction:column;gap:16px;">
      {% for faq in contact.faqs %}
      <details style="background:var(--color-white);border-radius:10px;padding:22px 24px;cursor:pointer;" data-reveal>
        <summary style="font-weight:600;color:var(--color-primary);list-style:none;display:flex;justify-content:space-between;align-items:center;">
          {{ faq.question }}
          <span style="color:var(--color-gold);font-size:1.3rem;transition:transform 0.3s;">+</span>
        </summary>
        <p style="margin-top:14px;font-size:0.93rem;color:var(--color-text-light);">{{ faq.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

{% endblock %}

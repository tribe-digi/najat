---
title: "Services — Dr Najat Amharar"
description: "Explore Dr Najat Amharar's functional medicine services — root-cause consultations, hormone health, gut health, and personalised wellness programmes."
activePage: services
headerScrolled: true
---
{% extends "base.njk" %}

{% block head %}
<style>
  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 70px;
    align-items: start;
    padding: var(--section-padding) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .service-detail:last-of-type { border-bottom: none; }
  .service-detail.reverse .service-detail__content { order: 1; }
  .service-detail.reverse .service-detail__visual  { order: 2; }

  .service-detail__visual {
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .service-detail__visual img {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .service-detail__label {
    position: absolute;
    bottom: 20px;
    left: 20px;
    background: var(--color-primary);
    color: var(--color-white);
    padding: 10px 18px;
    border-radius: var(--radius);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .service-detail__price {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    margin: 20px 0 24px;
    padding: 14px 20px;
    background: var(--color-off-white);
    border-radius: var(--radius);
  }

  .service-detail__price .amount {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 300;
    color: var(--color-primary);
  }

  .service-detail__price .label {
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .service-includes {
    margin: 20px 0 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .service-includes li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.93rem;
    color: var(--color-text-mid);
    line-height: 1.5;
  }

  .service-includes li::before {
    content: '✓';
    color: var(--color-sage);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 48px;
  }

  .package-card {
    background: var(--color-white);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 36px 28px;
    position: relative;
    transition: all var(--transition);
  }

  .package-card.featured {
    border-color: var(--color-sage);
    box-shadow: var(--shadow-md);
  }

  .package-card.featured::before {
    content: 'Most Popular';
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-sage);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 16px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .package-card__name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  .package-card__duration {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 18px;
  }

  .package-card__price {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 300;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 6px;
  }

  .package-card__period {
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 24px;
  }

  .package-card ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 28px;
  }

  .package-card ul li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--color-text-mid);
    line-height: 1.5;
  }

  .package-card ul li::before {
    content: '✓';
    color: var(--color-sage);
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .service-detail { grid-template-columns: 1fr; gap: 30px; }
    .service-detail.reverse .service-detail__content { order: 2; }
    .service-detail.reverse .service-detail__visual  { order: 1; }
    .packages-grid { grid-template-columns: 1fr; }
  }
</style>
{% endblock %}

{% block content %}

<!-- ===================== PAGE HERO ===================== -->
<section class="page-hero">
  <div class="container">
    <span class="eyebrow">Services</span>
    <h1>{{ services.headline }}</h1>
    <div class="divider divider--center"></div>
    <p class="lead">{{ services.intro }}</p>
  </div>
</section>

<!-- ===================== SERVICES DETAIL ===================== -->
<section class="section" style="padding-bottom:0;">
  <div class="container">

    {% for service in services.services_list %}
    <div class="service-detail{% if loop.index is even %} reverse{% endif %}" data-reveal>

      {% if loop.index is even %}
      <div class="service-detail__content">
        <span class="eyebrow">{{ service.eyebrow }}</span>
        <h2>{{ service.name }}</h2>
        <div class="divider"></div>
        <p>{{ service.description }}</p>
        {% if service.detail %}<p>{{ service.detail }}</p>{% endif %}

        {% if service.price %}
        <div class="service-detail__price">
          <span class="amount">{{ service.price }}</span>
          <span class="label">{{ service.price_label }}</span>
        </div>
        {% endif %}

        <ul class="service-includes">
          {% for inc in service.includes %}
          <li>{{ inc.item }}</li>
          {% endfor %}
        </ul>

        <a href="/contact/" class="btn btn--primary">Book Now</a>
      </div>
      <div class="service-detail__visual">
        <img src="{{ service.image }}" alt="{{ service.name }}" />
        <span class="service-detail__label">{{ service.eyebrow }}</span>
      </div>

      {% else %}
      <div class="service-detail__visual">
        <img src="{{ service.image }}" alt="{{ service.name }}" />
        <span class="service-detail__label">{{ service.eyebrow }}</span>
      </div>
      <div class="service-detail__content">
        <span class="eyebrow">{{ service.eyebrow }}</span>
        <h2>{{ service.name }}</h2>
        <div class="divider"></div>
        <p>{{ service.description }}</p>
        {% if service.detail %}<p>{{ service.detail }}</p>{% endif %}

        {% if service.price %}
        <div class="service-detail__price">
          <span class="amount">{{ service.price }}</span>
          <span class="label">{{ service.price_label }}</span>
        </div>
        {% endif %}

        <ul class="service-includes">
          {% for inc in service.includes %}
          <li>{{ inc.item }}</li>
          {% endfor %}
        </ul>

        <a href="/contact/" class="btn btn--primary">Book a Consultation</a>
      </div>
      {% endif %}

    </div>
    {% endfor %}

  </div>
</section>

<!-- ===================== PACKAGES ===================== -->
<section class="section section--off">
  <div class="container">
    <div class="section-header section-header--center" data-reveal>
      <span class="eyebrow">Programme Pricing</span>
      <h2>Choose your journey</h2>
      <div class="divider divider--center"></div>
      <p>All programmes are bespoke. Prices below are a guide — we'll discuss the right level of support during your discovery call.</p>
    </div>

    <div class="packages-grid">
      {% for pkg in services.packages %}
      <div class="package-card{% if pkg.featured %} featured{% endif %}" data-reveal>
        <div class="package-card__name">{{ pkg.name }}</div>
        <div class="package-card__duration">{{ pkg.duration }}</div>
        <div class="package-card__price">{{ pkg.price }}</div>
        <div class="package-card__period">{{ pkg.price_note }}</div>
        <ul>
          {% for inc in pkg.includes %}
          <li>{{ inc.item }}</li>
          {% endfor %}
        </ul>
        {% if pkg.featured %}
        <a href="/contact/" class="btn btn--primary" style="width:100%;justify-content:center;">Get Started</a>
        {% else %}
        <a href="/contact/" class="btn btn--outline" style="width:100%;justify-content:center;">Get Started</a>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ===================== CTA ===================== -->
<section class="cta-banner">
  <div class="container">
    <div class="cta-banner__inner">
      <div>
        <h2>Not sure where to start?</h2>
        <p>Book a free 20-minute discovery call and we'll discuss your symptoms and which programme is the best fit for you.</p>
      </div>
      <a href="/contact/" class="btn btn--gold" style="font-size:0.9rem;padding:18px 38px;flex-shrink:0;">Book a Free Call</a>
    </div>
  </div>
</section>

{% endblock %}

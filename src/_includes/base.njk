<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  {% if ogTitle %}
  <meta property="og:title" content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  {% endif %}
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  {% block head %}{% endblock %}
</head>
<body>

<!-- ===================== HEADER ===================== -->
<header class="site-header{% if headerScrolled %} scrolled{% endif %}" id="site-header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="nav__logo">
        <span class="nav__logo-name">{{ settings.doctor_name }}</span>
        <span class="nav__logo-title">{{ settings.subtitle }}</span>
      </a>
      <ul class="nav__links">
        <li><a href="/"{% if activePage == 'home' %} class="active"{% endif %}>Home</a></li>
        <li><a href="/about/"{% if activePage == 'about' %} class="active"{% endif %}>About</a></li>
        <li><a href="/services/"{% if activePage == 'services' %} class="active"{% endif %}>Services</a></li>
        <li><a href="/contact/"{% if activePage == 'contact' %} class="active"{% endif %}>Contact</a></li>
        <li><a href="/contact/" class="nav__cta">Book a Call</a></li>
      </ul>
      <button class="nav__hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile nav overlay -->
<div class="mobile-nav">
  <button class="mobile-nav__close" aria-label="Close menu">&times;</button>
  <a href="/">Home</a>
  <a href="/about/">About</a>
  <a href="/services/">Services</a>
  <a href="/contact/">Contact</a>
  <a href="/contact/" style="color:var(--color-gold-light)">Book a Call</a>
</div>

{% block content %}{% endblock %}

<!-- ===================== FOOTER ===================== -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand__name">{{ settings.doctor_name }}</div>
        <div class="footer-brand__title">Functional Medicine Physician</div>
        <p>{{ settings.footer_tagline }}</p>
      </div>
      <div class="footer-col">
        <h5>Pages</h5>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/services/">Services</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Services</h5>
        <ul>
          <li><a href="/services/">Root-Cause Consultation</a></li>
          <li><a href="/services/">Hormone Health</a></li>
          <li><a href="/services/">Gut Health</a></li>
          <li><a href="/services/">Wellness Plans</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Get in Touch</h5>
        <ul>
          <li><a href="/contact/">Book a Call</a></li>
          <li><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 {{ settings.doctor_name }}. All rights reserved.</span>
      <span>Designed with care for your health.</span>
    </div>
  </div>
</footer>

<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
<script src="/js/main.js"></script>
</body>
</html>
